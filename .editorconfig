root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 88

[*.{sv,svh,v,vh}]
indent_size = 4

[*.rdl]
indent_size = 4

[*.{yml,yaml,core}]
indent_size = 2

[Makefile]
indent_style = tab
